---
import { getLangFromUrl, t, getLocalePath } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const i = t(lang);
---

<section class="relative overflow-hidden py-24 sm:py-32 lg:py-40">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-brand-accent/10 via-brand-bg to-brand-bg"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-brand-accent/20 via-transparent to-transparent"></div>

  <div class="relative mx-auto max-w-5xl px-6 text-center">
    <!-- Tagline -->
    <h1 class="text-5xl font-extrabold tracking-tight sm:text-6xl lg:text-7xl">
      <span class="bg-gradient-to-r from-white via-slate-200 to-slate-400 bg-clip-text text-transparent">
        {i.hero.tagline}
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="mt-6 text-lg text-slate-400 sm:text-xl lg:text-2xl">
      {i.hero.subtitle}
      <span class="text-brand-accent-light font-semibold">{i.hero.subtitleHighlight}</span>
    </p>

    <!-- Description -->
    <p class="mt-4 text-base text-slate-500 sm:text-lg max-w-2xl mx-auto">
      {i.hero.description}
    </p>

    <!-- CTA Buttons -->
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={getLocalePath(lang, '/docs/getting-started/quick-start')}
        class="inline-flex items-center rounded-lg bg-brand-accent px-6 py-3 text-base font-semibold text-white shadow-lg shadow-brand-accent/25 transition hover:bg-brand-accent-light hover:shadow-brand-accent-light/25"
      >
        {i.hero.cta}
      </a>
      <a
        href="https://github.com/omnigram-dev/omnigram"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center rounded-lg border border-brand-border px-6 py-3 text-base font-semibold text-slate-300 transition hover:border-slate-400 hover:text-white"
      >
        {i.hero.github}
      </a>
    </div>

    <!-- Docker command badge -->
    <div class="mt-10 inline-flex items-center gap-3 rounded-full border border-brand-border bg-brand-bg-light/60 px-5 py-2.5 backdrop-blur">
      <span class="text-xs font-medium uppercase tracking-wider text-slate-500">Quick start</span>
      <code class="font-mono text-sm text-brand-accent-light">{i.hero.docker}</code>
    </div>
  </div>
</section>
