---
import { getLangFromUrl, t, getLocalePath } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const i = t(lang);
---

<section class="py-20 sm:py-28">
  <div class="mx-auto max-w-4xl px-6">
    <div class="relative overflow-hidden rounded-3xl border border-brand-border">
      <!-- Gradient background -->
      <div class="absolute inset-0 bg-gradient-to-br from-brand-accent/20 via-brand-bg-light to-brand-accent-light/10"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-brand-accent/10 via-transparent to-transparent"></div>

      <div class="relative px-8 py-16 text-center sm:px-16 sm:py-20">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">
          {i.cta.title}
        </h2>
        <p class="mt-4 text-lg text-slate-400">
          {i.cta.subtitle}
        </p>

        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={getLocalePath(lang, '/docs/getting-started/quick-start')}
            class="inline-flex items-center rounded-lg bg-brand-accent px-6 py-3 text-base font-semibold text-white shadow-lg shadow-brand-accent/25 transition hover:bg-brand-accent-light hover:shadow-brand-accent-light/25"
          >
            {i.cta.primary}
          </a>
          <a
            href={getLocalePath(lang, '/docs/getting-started/quick-start')}
            class="inline-flex items-center rounded-lg border border-brand-border px-6 py-3 text-base font-semibold text-slate-300 transition hover:border-slate-400 hover:text-white"
          >
            {i.cta.secondary}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
