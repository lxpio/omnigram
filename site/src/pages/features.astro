---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';

const sections = [
  { icon: '\u{1F916}', title: 'Reading Companion', desc: 'Not a chatbot. A reading partner with configurable personality \u2014 like TARS from Interstellar. Adjust proactivity, style, depth, and warmth. It can be a silent assistant, a Socratic mentor, or a friend reading alongside you.', details: 'Personality presets: Silent Helper, Reading Buddy, Academic Mentor. Fine-tune with sliders in advanced mode.' },
  { icon: '\u{2728}', title: 'Ambient Intelligence', desc: 'AI is woven into every surface. Turn to a new chapter \u2014 a context bar fades in with a recap. Select a word \u2014 a definition appears. AI surfaces cross-book connections in the margin. You never press an AI button.', details: '4-layer reader AI: Context Bar (auto) \u2192 Inline Glossary (auto) \u2192 Margin Notes (auto, max 3/chapter) \u2192 Companion Panel (manual).' },
  { icon: '\u{1F4A1}', title: 'Insight, Not Statistics', desc: 'No bar charts or heatmaps. AI narrates your reading journey: what domains you explored, which books connect to each other, how your interests are evolving. Notes organized by concept across all books, not scattered highlights.', details: 'Three layers: Reading Narrative (AI story) \u2192 Knowledge Network (concept graph) \u2192 Cross-Book Connections (thematic relationships).' },
  { icon: '\u{1F3A7}', title: 'TTS Audiobooks', desc: 'Turn any ebook into a high-quality audiobook. Your companion reads to you in their configured voice. Server-side processing so your phone stays cool.', details: 'Backed by Kokoro / Edge TTS (server sidecar) + sherpa-onnx (on-device). Multiple voices, adjustable speed.' },
  { icon: '\u{1F4DA}', title: 'Smart Library', desc: 'Import a book, it\u2019s ready. AI auto-generates tags, summaries, difficulty level, and reading time estimates. Books group by topic, not filename. Search by meaning: \u201Cthe book about procrastination\u201D works.', details: 'Two-phase import: instant metadata parsing, then background AI enrichment. Batch import of 50 books handled gracefully.' },
  { icon: '\u{1F512}', title: 'Privacy as Freedom', desc: 'A completely isolated hidden library with biometric access. Zero trace in the main interface. Full reading experience and AI inside. Privacy protects against others\u2019 eyes, not your own reading experience.', details: 'Encrypted storage with platform keystore. Quick lock on app switch. Optional encrypted backup to separate WebDAV path.' },
];
---
<BaseLayout title="Features" description="AI changes everything, but you can't point to where it is">
  <div class="py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <h1 class="text-4xl font-extrabold text-slate-100 text-center mb-16">Features</h1>
      {sections.map((s, i) => (
        <div class={`flex flex-col md:flex-row gap-8 mb-20 items-center ${i % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
          <div class="flex-1">
            <div class="text-4xl mb-4">{s.icon}</div>
            <h2 class="text-2xl font-bold text-slate-100">{s.title}</h2>
            <p class="text-slate-400 mt-3 leading-relaxed">{s.desc}</p>
            <p class="text-slate-500 text-sm mt-3 italic">{s.details}</p>
          </div>
          <div class="flex-1 bg-brand-bg-light border border-brand-border rounded-xl h-48 flex items-center justify-center text-slate-600 text-sm">
            [ Screenshot ]
          </div>
        </div>
      ))}
    </div>
  </div>
  <CTA />
</BaseLayout>
