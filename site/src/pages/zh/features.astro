---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';

const sections = [
  { icon: '\u{1F916}', title: '阅读伴侣', desc: '不是聊天机器人，而是一个可配置性格的阅读伙伴——像《星际穿越》里的 TARS。可以调节主动性、风格、深度和温度。它可以是安静的书童，也可以是苏格拉底式的导师，也可以是和你一起读书的朋友。', details: '预设人格：默默帮忙型、读书搭子型、学术导师型。高级模式可微调四维滑条。' },
  { icon: '\u{2728}', title: '隐形智能', desc: 'AI 融入每一个界面。翻到新章节——上下文条淡入一句前情提要。选中一个词——浮窗里自然出现释义。页边自动出现跨书知识关联。你没有点任何"AI 按钮"。', details: '阅读器四层 AI：上下文条（自动）→ 内联释义（自动）→ 页边批注（自动，每章最多 3 条）→ 伴侣面板（手动召唤）。' },
  { icon: '\u{1F4A1}', title: '洞察而非统计', desc: '没有柱状图和热力图。AI 叙事性地讲述你的阅读旅程：你深入了什么领域，哪些书之间有知识关联，你的兴趣正在走向什么方向。笔记不是散落的高亮，而是按概念跨书聚合的知识网络。', details: '三层结构：阅读叙事（AI 故事）→ 知识网络（概念图谱）→ 跨书关联（主题关系）。' },
  { icon: '\u{1F3A7}', title: 'TTS 有声书', desc: '任意电子书一键生成有声书。用你阅读伴侣配置的声音朗读给你听。服务端处理，不占用手机资源。', details: '支持 Kokoro / Edge TTS（服务端 sidecar）+ sherpa-onnx（设备端）。多种音色，可调速度。' },
  { icon: '\u{1F4DA}', title: '智能书架', desc: '导入一本书，它就准备好了。AI 自动生成标签、摘要、难度评估和阅读时长估算。书按主题分组，不是按文件名排列。语义搜索——"那本讲拖延症的书"也能找到。', details: '两阶段导入：即时解析元数据，然后后台 AI 加工。批量导入 50 本书也能优雅处理。' },
  { icon: '\u{1F512}', title: '隐私即自由', desc: '完全隔离的隐身书房，生物识别进入。主界面零痕迹。里面有完整的阅读体验和 AI 功能。隐私保护的是别人的视线，不是你自己的阅读体验。', details: '平台密钥加密存储。切换应用即锁定。可选加密备份到独立 WebDAV 路径。' },
];
---
<BaseLayout title="功能" description="AI 改变了一切，但你找不到 AI 在哪">
  <div class="py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <h1 class="text-4xl font-extrabold text-slate-100 text-center mb-16">功能</h1>
      {sections.map((s, i) => (
        <div class={`flex flex-col md:flex-row gap-8 mb-20 items-center ${i % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
          <div class="flex-1">
            <div class="text-4xl mb-4">{s.icon}</div>
            <h2 class="text-2xl font-bold text-slate-100">{s.title}</h2>
            <p class="text-slate-400 mt-3 leading-relaxed">{s.desc}</p>
            <p class="text-slate-500 text-sm mt-3 italic">{s.details}</p>
          </div>
          <div class="flex-1 bg-brand-bg-light border border-brand-border rounded-xl h-48 flex items-center justify-center text-slate-600 text-sm">
            [ 截图 ]
          </div>
        </div>
      ))}
    </div>
  </div>
  <CTA />
</BaseLayout>
